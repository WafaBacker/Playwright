{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true, // Crucial for test-data.json
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "." , 
  },

  "include": ["tests/**/*.ts", "pages/**/*.ts", "TestData/**/*.json"]
}